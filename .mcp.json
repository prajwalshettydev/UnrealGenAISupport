{
  "mcpServers": {
    "unreal-handshake": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "Content/Python",
        "--with",
        "fastmcp",
        "--with",
        "mss",
        "python",
        "Content/Python/mcp_server.py"
      ],
      "env": {
        "UNREAL_HOST": "localhost",
        "UNREAL_PORT": "9877"
      }
    }
  }
}
